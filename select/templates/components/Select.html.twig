{# @prop size 'sm'|'lg' The select size. Defaults to normal size #}
{# @block content The select options (`<option>` elements) #}
{%- props size = null -%}

<select
    class="form-select{% if size %} form-select-{{ size }}{% endif %} {{ attributes.render('class') }}"
    {{ attributes }}
>
    {%- block content %}{% endblock -%}
</select>
