{# @prop variant 'primary'|'secondary'|'success'|'danger'|'warning'|'info'|'light'|'dark'|'link'|'outline-primary'|'outline-secondary'|'outline-success'|'outline-danger'|'outline-warning'|'outline-info'|'outline-light'|'outline-dark' The modal trigger style variant. Defaults to `primary` #}
{# @prop size 'sm'|'lg' The modal trigger size. Defaults to normal size #}
{# @block content The label of the modal trigger #}

{%- set trigger_content -%}
	{%- block content %}{% endblock -%}
{%- endset -%}

<twig:Button
	data-bs-toggle="modal"
	data-bs-target="#{{ _modal_id }}"
	{{ ...attributes }}
>
	{{- trigger_content -}}
</twig:Button>
