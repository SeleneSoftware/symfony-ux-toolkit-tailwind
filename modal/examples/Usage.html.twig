<twig:Modal id="exampleModal">
	<twig:Modal:Trigger
		variant="primary | secondary | success | danger | warning | info | light | dark | link | outline-primary | outline-secondary | outline-success | outline-danger | outline-warning | outline-info | outline-light | outline-dark"
	>
		Open Modal
	</twig:Modal:Trigger>
	<twig:Modal:Content>
		<twig:Modal:Header>
			<twig:Modal:Title>Modal Title</twig:Modal:Title>
			<twig:Modal:Close />
		</twig:Modal:Header>
		<twig:Modal:Body>
			<p>This is a modal body with some example content.</p>
		</twig:Modal:Body>
		<twig:Modal:Footer>
			<twig:Button variant="secondary" data-bs-dismiss="modal">Close</twig:Button>
			<twig:Button variant="primary">Save changes</twig:Button>
		</twig:Modal:Footer>
	</twig:Modal:Content>
</twig:Modal>
