{# @prop href string URL for the brand link #}
{# @block content The brand content (text, image, etc.) #}
{%- props
    href = null
-%}

<{{ href ? 'a' : 'span' }}
    class="navbar-brand {{ attributes.render('class') }}"
{% if href %}
    href="{{ href }}"
{% endif %}
    {{ attributes }}
>
    {%- block content %}{% endblock -%}
</{{ href ? 'a' : 'span' }}>
