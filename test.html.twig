<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Symfony UX Toolkit - Bootstrap Components</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body class="p-4">
    <div class="container">
        <h1 class="mb-4">Symfony UX Toolkit - Bootstrap Components</h1>

        <section class="mb-5">
            <h2 class="mb-3">Alert</h2>
            {{ include('alert/examples/Demo.html.twig') }}
            {{ include('alert/examples/Action.html.twig') }}
            {{ include('alert/examples/Dismissing.html.twig') }}
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Badge</h2>
            {{ include('badge/examples/Demo.html.twig') }}
            {{ include('badge/examples/Pill.html.twig') }}
            {{ include('badge/examples/As link.html.twig') }}
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Button</h2>
            {{ include('button/examples/Demo.html.twig') }}
            {{ include('button/examples/Outline.html.twig') }}
            {{ include('button/examples/Size.html.twig') }}
            {{ include('button/examples/Disabled.html.twig') }}
            {{ include('button/examples/As link.html.twig') }}
            {{ include('button/examples/Icon.html.twig') }}
            {{ include('button/examples/Loading.html.twig') }}
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Button Group</h2>
            {{ include('button-group/examples/Demo.html.twig') }}
            {{ include('button-group/examples/Size.html.twig') }}
            {{ include('button-group/examples/Orientation.html.twig') }}
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Breadcrumb</h2>
            {{ include('breadcrumb/examples/Demo.html.twig') }}
            {{ include('breadcrumb/examples/Custom Separator.html.twig') }}
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Card</h2>
            <div class="row">
                <div class="col-md-6">
                    {{ include('card/examples/Demo.html.twig') }}
                </div>
                <div class="col-md-6">
                    {{ include('card/examples/With image.html.twig') }}
                </div>
            </div>
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Checkbox & Radio</h2>
            {{ include('checkbox/examples/Demo.html.twig') }}
            {{ include('checkbox/examples/Inline.html.twig') }}
            {{ include('checkbox/examples/Disabled.html.twig') }}
            {{ include('radio/examples/Demo.html.twig') }}
            {{ include('radio/examples/Inline.html.twig') }}
            {{ include('radio/examples/Disabled.html.twig') }}
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Collapsible</h2>
            {{ include('collapsible/examples/Demo.html.twig') }}
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Input, Input Group, Label</h2>
            {{ include('input/examples/Demo.html.twig') }}
            {{ include('input/examples/Size.html.twig') }}
            {{ include('input/examples/Disabled.html.twig') }}
            {{ include('input/examples/File.html.twig') }}
            {{ include('input/examples/Plain text.html.twig') }}
            {{ include('input-group/examples/Demo.html.twig') }}
            {{ include('input-group/examples/Size.html.twig') }}
            {{ include('label/examples/Demo.html.twig') }}
            {{ include('label/examples/Floating.html.twig') }}
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Modal</h2>
            {{ include('modal/examples/Demo.html.twig') }}
            {{ include('modal/examples/Static.html.twig') }}
            {{ include('modal/examples/Size.html.twig') }}
            {{ include('modal/examples/Centered.html.twig') }}
            {{ include('modal/examples/Scrollable.html.twig') }}
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Pagination</h2>
            {{ include('pagination/examples/Demo.html.twig') }}
            {{ include('pagination/examples/Disabled.html.twig') }}
            {{ include('pagination/examples/Icon.html.twig') }}
            {{ include('pagination/examples/Size.html.twig') }}
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Progress</h2>
            {{ include('progress/examples/Demo.html.twig') }}
            {{ include('progress/examples/Striped.html.twig') }}
            {{ include('progress/examples/Animated.html.twig') }}
            {{ include('progress/examples/With label.html.twig') }}
        </section>
        
        <section class="mb-5">
            <h2 class="mb-3">Select</h2>
            {{ include('select/examples/Demo.html.twig') }}
            {{ include('select/examples/Multiple.html.twig') }}
            {{ include('select/examples/Disabled.html.twig') }}
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Spinner</h2>
            {{ include('spinner/examples/Demo.html.twig') }}
            {{ include('spinner/examples/Color.html.twig') }}
            {{ include('spinner/examples/Size.html.twig') }}
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Table</h2>
            {{ include('table/examples/Demo.html.twig') }}
            {{ include('table/examples/Striped.html.twig') }}
            {{ include('table/examples/Bordered.html.twig') }}
            {{ include('table/examples/Hoverable.html.twig') }}
            {{ include('table/examples/Small.html.twig') }}
            {{ include('table/examples/Dark.html.twig') }}
            {{ include('table/examples/Responsive.html.twig') }}
            {{ include('table/examples/Without border.html.twig') }}
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Tabs</h2>
            <twig:Tabs id="demoTabs">
                <twig:block name="navigation">
                    <twig:Tabs:Item id="home" active="true">Home</twig:Tabs:Item>
                    <twig:Tabs:Item id="profile">Profile</twig:Tabs:Item>
                    <twig:Tabs:Item id="contact">Contact</twig:Tabs:Item>
                </twig:block>
                <twig:Tabs:Pane id="home" active="true">
                    Home tab content
                </twig:Tabs:Pane>
                <twig:Tabs:Pane id="profile">
                    Profile tab content
                </twig:Tabs:Pane>
                <twig:Tabs:Pane id="contact">
                    Contact tab content
                </twig:Tabs:Pane>
            </twig:Tabs>
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Toast</h2>
            <twig:Toast show="true">
                <twig:block name="header">
                    <strong class="me-auto">Notification</strong>
                    <small>Just now</small>
                </twig:block>
                Hello, world! This is a toast message.
            </twig:Toast>
        </section>
    </div>
</body>
</html>
