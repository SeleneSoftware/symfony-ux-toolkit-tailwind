<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Symfony UX Toolkit - Bootstrap Components</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body class="p-4">
    <div class="container">
        <h1 class="mb-4">Symfony UX Toolkit - Bootstrap Components</h1>

        <section class="mb-5">
            <h2 class="mb-3">Alert</h2>
            <twig:Alert variant="success" dismissible="true">
                This is a success alert!
            </twig:Alert>
            <twig:Alert variant="danger">
                <twig:Alert:Heading>Error</twig:Alert:Heading>
                Something went wrong.
            </twig:Alert>
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Badge</h2>
            <twig:Badge variant="danger">New</twig:Badge>
            <twig:Badge variant="primary" pill="true">99+</twig:Badge>
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Button</h2>
            <twig:Button variant="primary">Primary</twig:Button>
            <twig:Button variant="secondary">Secondary</twig:Button>
            <twig:Button variant="success" outline="true">Outline</twig:Button>
            <twig:Button variant="danger" size="lg">Large Danger</twig:Button>
            <twig:Button variant="link" href="https://symfony.com">Link Button</twig:Button>
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Button Group</h2>
            <twig:ButtonGroup>
                <twig:Button variant="outline-primary">Left</twig:Button>
                <twig:Button variant="outline-primary">Middle</twig:Button>
                <twig:Button variant="outline-primary">Right</twig:Button>
            </twig:ButtonGroup>
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Breadcrumb</h2>
            <twig:Breadcrumb>
                <twig:Breadcrumb:Item href="/">Home</twig:Breadcrumb:Item>
                <twig:Breadcrumb:Item href="/library">Library</twig:Breadcrumb:Item>
                <twig:Breadcrumb:Item active="true">Data</twig:Breadcrumb:Item>
            </twig:Breadcrumb>
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Card</h2>
            <div class="row">
                <div class="col-md-6">
                    <twig:Card>
                        <twig:block name="top">
                            <twig:Card:Image src="https://placehold.co/600x200" alt="Placeholder" />
                        </twig:block>
                        <twig:block name="header">
                            <twig:Card:Title>Card Title</twig:Card:Title>
                        </twig:block>
                        <twig:Card:Body>
                            <twig:Card:Text>Some quick example text to build on the card title.</twig:Card:Text>
                        </twig:Card:Body>
                        <twig:block name="footer">
                            Last updated 3 mins ago
                        </twig:block>
                    </twig:Card>
                </div>
            </div>
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Checkbox</h2>
            <twig:Checkbox label="Default checkbox" />
            <twig:Checkbox label="Checked checkbox" checked="true" />
            <twig:Checkbox label="Inline checkbox" inline="true" />
            <twig:Checkbox label="Disabled checkbox" disabled="true" />
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Collapse</h2>
            <twig:Button data-bs-toggle="collapse" data-bs-target="#demoCollapse">
                Toggle Collapse
            </twig:Button>
            <twig:Collapse id="demoCollapse" class="mt-2 p-3 border">
                This content can be collapsed!
            </twig:Collapse>
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Form Group + Input</h2>
            
            <twig:InputGroup class="mb-3">
                <twig:Input placeholder="Username" />
                <twig:InputGroup:Text>@</twig:InputGroup:Text>
                <twig:Input placeholder="Domain" />
                <twig:InputGroup:Text>.com</twig:InputGroup:Text>
            </twig:InputGroup>
            
            <twig:FormGroup label="Email address" for="email" required="true" help="We'll never share your email.">
                <twig:Input type="email" id="email" placeholder="Enter email" />
            </twig:FormGroup>

            <twig:FormGroup label="Password" for="password">
                <twig:Input type="password" id="password" placeholder="Password" />
            </twig:FormGroup>

            <twig:FormGroup label="Comments" for="comments">
                <twig:Textarea id="comments" rows="3" placeholder="Your comments..." />
            </twig:FormGroup>

            <twig:FormGroup label="Fruit" for="fruit">
                <twig:Select id="fruit">
                    <option>apple</option>
                    <option>pear</option>
                    <option>grape</option>
                </twig:Select>
            </twig:FormGroup>
            
            <twig:FormGroup label="Fruit (with array)" for="fruit2">
                <twig:Select id="fruit2" :options="{
                    apple: 'apple',
                    pear: 'pear',
                    grape: 'grape'
                }" />
            </twig:FormGroup>
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Modal</h2>
            <twig:Button data-bs-toggle="modal" data-bs-target="#exampleModal">
                Launch Demo Modal
            </twig:Button>
            <twig:Modal id="exampleModal">
                <twig:block name="header">
                    <h5 class="modal-title">Modal Demo</h5>
                </twig:block>
                <p>This is a modal body with some example content.</p>
                <twig:block name="footer">
                    <twig:Button variant="secondary" data-bs-dismiss="modal">
                        Close
                    </twig:Button>
                </twig:block>
            </twig:Modal>
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Navbar</h2>
            <twig:Navbar id="mainNav" variant="dark" background="dark">
                <twig:block name="brand">
                    <twig:Navbar:Brand href="#">My App</twig:Navbar:Brand>
                </twig:block>
                <twig:Navbar:Nav>
                    <twig:Navbar:Item href="#" active="true">Home</twig:Navbar:Item>
                    <twig:Navbar:Item href="#">Features</twig:Navbar:Item>
                    <twig:Navbar:Item href="#">Pricing</twig:Navbar:Item>
                </twig:Navbar:Nav>
            </twig:Navbar>
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Pagination</h2>
            <twig:Pagination>
                <twig:Pagination:Item page="Previous" href="#" />
                <twig:Pagination:Item page="1" href="#" />
                <twig:Pagination:Item page="2" href="#" active="true" />
                <twig:Pagination:Item page="3" href="#" />
                <twig:Pagination:Item page="Next" href="#" />
            </twig:Pagination>
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Progress</h2>
            <twig:Progress value="75" />
            <twig:Progress value="50" variant="success" striped="true" animated="true" class="mt-2" />
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Spinner</h2>
            <twig:Spinner /> Loading...
            <twig:Spinner size="sm" class="ms-3" /> Small
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Table</h2>
            <twig:Table striped="true" hover="true">
                <twig:block name="header">
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Email</th>
                    </tr>
                </twig:block>
                <tr><td>1</td><td>John</td><td>john@example.com</td></tr>
                <tr><td>2</td><td>Jane</td><td>jane@example.com</td></tr>
                <twig:block name="footer">
                    <tr><td colspan="3">Total: 2</td></tr>
                </twig:block>
            </twig:Table>
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Tabs</h2>
            <twig:Tabs id="demoTabs">
                <twig:block name="navigation">
                    <twig:Tabs:Item id="home" active="true">Home</twig:Tabs:Item>
                    <twig:Tabs:Item id="profile">Profile</twig:Tabs:Item>
                    <twig:Tabs:Item id="contact">Contact</twig:Tabs:Item>
                </twig:block>
                <twig:Tabs:Pane id="home" active="true">
                    Home tab content
                </twig:Tabs:Pane>
                <twig:Tabs:Pane id="profile">
                    Profile tab content
                </twig:Tabs:Pane>
                <twig:Tabs:Pane id="contact">
                    Contact tab content
                </twig:Tabs:Pane>
            </twig:Tabs>
        </section>

        <section class="mb-5">
            <h2 class="mb-3">Toast</h2>
            <twig:Toast show="true">
                <twig:block name="header">
                    <strong class="me-auto">Notification</strong>
                    <small>Just now</small>
                </twig:block>
                Hello, world! This is a toast message.
            </twig:Toast>
        </section>
    </div>
</body>
</html>
