{# @prop inline boolean Whether the radio container is inline. Defaults to false #}
{# @block content The radio input, typically `Radio` #}

{%- set container_content -%}
    {%- block content %}{% endblock -%}
{%- endset -%}

<twig:Checkbox:Container {{ ...attributes }}>
    {{- container_content -}}
</twig:Checkbox:Container>
