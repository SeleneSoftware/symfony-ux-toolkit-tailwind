{# @prop variant 'primary'|'secondary'|'success'|'danger'|'warning'|'info'|'light'|'dark' The spinner color. Defaults to `primary` #}
{# @prop type 'border'|'grow' The spinner type. Defaults to `border` #}
{# @prop small boolean Small spinner size. Defaults to `false` #}
{%- props variant = 'primary', type = 'border', small = false -%}

<div
    class="spinner-{{ type }} text-{{ variant }}{% if small %} spinner-{{ type }}-sm{% endif %} {{ attributes.render('class') }}"
    role="status"
    {{ attributes }}
></div>
