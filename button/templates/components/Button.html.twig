{# @prop variant 'primary'|'secondary'|'success'|'danger'|'warning'|'info'|'light'|'dark'|'link'|'outline-primary'|'outline-secondary'|'outline-success'|'outline-danger'|'outline-warning'|'outline-info'|'outline-light'|'outline-dark' The button style variant. Defaults to `primary` #}
{# @prop size 'sm'|'lg' The button size. Defaults to normal size #}
{# @prop as 'button' The HTML tag to render. Defaults to `button` #}
{# @prop disabled boolean Whether the button is disabled. Defaults to false #}
{# @block content The button label and/or icon #}
{%- props variant = 'primary', size = null, as = 'button', disabled = false -%}
{#
inline-block rounded-sm border border-indigo-600 px-12 py-3 text-sm font-medium text-white hover:bg-transparent hover:text-indigo-600
inline-block rounded-sm border border-indigo-600 px-12 py-3 text-sm font-medium text-indigo-600 hover:bg-indigo-600 hover:text-white
#}
{%- set style = html_cva(
    base: 'inline-block rounded-sm border border-indigo-600 px-12 py-3 text-sm font-medium',
    variants: {
        variant: {
            solid: "bg-indigo-600 text-white hover:bg-transparent hover:text-indigo-600",
            hollow: "inline-block rounded-sm border border-indigo-600 px-12 py-3 text-sm font-medium text-indigo-600 hover:bg-indigo-600 hover:text-white",
        },
        size: {
            default: '',
            sm: 'btn-sm',
            lg: 'btn-lg',
        },
    },
) -%}

<{{ as }}
    class="{{ style.apply({variant, size}, attributes.render('class')) }}{% if as == 'a' and disabled %} disabled{% endif %}"
    {% if as == 'a' %}role="button"{% endif %}
    {% if as == 'a' and disabled %}aria-disabled="true"{% elseif disabled %}disabled{% endif %}
    {{ attributes }}
>
    {%- block content %}{% endblock -%}
</{{ as }}>
