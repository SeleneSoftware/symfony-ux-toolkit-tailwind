{# @prop size 'sm'|'lg' The input size. Defaults to normal size #}
{# @prop plaintext boolean Whether to use plaintext style #}
{%- props size = null, plaintext = false -%}

{%- set style = html_cva(
	base: '',
	variants: {
		plaintext: {
			false: 'form-control',
			true: 'form-control-plaintext',
		},
		size: {
			sm: 'form-control-sm',
			lg: 'form-control-lg',
		},
	}
) -%}

<input
	class="{{ style.apply({plaintext, size}, attributes.render('class')) }}"
    {{ attributes }}
>
