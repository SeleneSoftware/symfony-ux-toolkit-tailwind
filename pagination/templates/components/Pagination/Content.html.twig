{# @prop size 'sm'|'lg' The pagination size. Defaults to normal size #}
{# @block content The pagination items, typically multiple `Pagination:Item` components #}
{%- props size = null -%}

{%- set style = html_cva(
	base: 'pagination',
	variants: {
		size: {
			default: '',
			sm: 'pagination-sm',
			lg: 'pagination-lg',
		},
	},
) -%}

<ul
	class="{{ style.apply({size}, attributes.render('class')) }}"
	{{ attributes }}
>
	{%- block content %}{% endblock -%}
</ul>
