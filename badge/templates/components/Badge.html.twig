{# @prop variant 'primary'|'secondary'|'success'|'danger'|'warning'|'info'|'light'|'dark' The visual style variant. Defaults to `primary` #}
{# @prop as 'span' The HTML tag to render. Defaults to `span` #}
{# @prop shape 'rounded'|'pill' The badge shape. Defaults to `rounded` #}
{# @block content The badge label or content #}
{%- props variant = 'primary', as = 'span', shape = 'rounded' -%}

{%- set style = html_cva(
    base: 'badge',
    variants: {
        variant: {
            primary: 'text-bg-primary',
            secondary: 'text-bg-secondary',
            success: 'text-bg-success',
            danger: 'text-bg-danger',
            warning: 'text-bg-warning',
            info: 'text-bg-info',
            light: 'text-bg-light',
            dark: 'text-bg-dark',
        },
        shape: {
            rounded: '',
            pill: 'rounded-pill',
        },
    },
) -%}

<{{ as }}
    class="{{ style.apply({variant, shape}, attributes.render('class')) }}"
    {{ attributes }}
>
    {%- block content %}{% endblock -%}
</{{ as }}>
