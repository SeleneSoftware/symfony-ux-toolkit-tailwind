{%- set subscribers = [
    { name: 'John Doe', email: 'john.doe@example.com' },
    { name: 'Jane Smith', email: 'jane.smith@example.com' }
] -%}
<twig:Table>
	<twig:Table:Caption>Subscribers</twig:Table:Caption>
	<twig:Table:Header>
		<twig:Table:Row>
			<twig:Table:Head>Name</twig:Table:Head>
			<twig:Table:Head>Email</twig:Table:Head>
		</twig:Table:Row>
	</twig:Table:Header>
	<twig:Table:Body>
		{% for subscriber in subscribers %}
			<twig:Table:Row>
				<twig:Table:Cell>{{ subscriber.name }}</twig:Table:Cell>
				<twig:Table:Cell>{{ subscriber.email }}</twig:Table:Cell>
			</twig:Table:Row>
		{% endfor %}
	</twig:Table:Body>
	<twig:Table:Footer>
		<twig:Table:Row>
			<twig:Table:Cell colspan="2">Total: {{ subscribers|length }}</twig:Table:Cell>
		</twig:Table:Row>
	</twig:Table:Footer>
</twig:Table>
