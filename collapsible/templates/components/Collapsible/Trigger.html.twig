{# @prop variant 'primary'|'secondary'|'success'|'danger'|'warning'|'info'|'light'|'dark'|'link'|'outline-primary'|'outline-secondary'|'outline-success'|'outline-danger'|'outline-warning'|'outline-info'|'outline-light'|'outline-dark' The collapsible trigger style variant. Defaults to `primary` #}
{# @prop size 'sm'|'lg' The collapsible trigger size. Defaults to normal size #}
{# @block content The label of the collapsible trigger #}

{%- set trigger_content -%}
    {%- block content %}{% endblock -%}
{%- endset -%}

<twig:Button
    data-bs-toggle="collapse"
    data-bs-target="#{{ _collapsible_id }}"
    aria-controls="{{ _collapsible_id }}"
    {{ ...attributes }}
>
    {{- trigger_content -}}
</twig:Button>
