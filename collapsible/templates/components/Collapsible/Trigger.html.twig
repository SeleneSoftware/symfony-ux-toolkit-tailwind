{# @block content The label of the collapsible trigger #}

{%- set trigger_content -%}
    {%- block content %}{% endblock -%}
{%- endset -%}

<twig:Button
    data-bs-toggle="collapse"
    data-bs-target="#{{ _collapsible_id }}"
    aria-controls="{{ _collapsible_id }}"
    {{ ...attributes }}
>
    {{- trigger_content -}}
</twig:Button>
