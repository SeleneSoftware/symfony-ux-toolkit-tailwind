{# @prop label string The form field label #}
{# @prop help string Help text displayed below the input #}
{# @prop error string Error message (displays with validation styling) #}
{# @prop required boolean Whether the field is required #}
{# @prop for string The id of the input this label is for #}
{# @block content The form control (input, select, textarea, etc.) #}
{%- props 
    label = null,
    help = null,
    error = null,
    required = false,
    for = null
-%}

<div class="mb-3 {{ attributes.render('class') }}" {{ attributes }}>
    {% if label is not null %}
        <twig:Label
            for="{{ for|default(null) }}"
            class="{{ required ? 'required' : '' }}"
        >
            {{ label }}
        </twig:Label>
    {% endif %}
    
    {%- block content %}{% endblock -%}
    
    {% if error %}
        <div class="invalid-feedback d-block">
            {{ error }}
        </div>
    {% elseif help %}
        <div class="form-text">
            {{ help }}
        </div>
    {% endif %}
</div>
