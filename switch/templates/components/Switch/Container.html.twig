{# @prop inline boolean Whether the switch container is inline. Defaults to false #}
{# @block content The switch input, typically `Switch` #}

{%- set container_content -%}
    {%- block content %}{% endblock -%}
{%- endset -%}

<twig:Checkbox:Container class="form-switch {{ attributes.render('class') }}" {{ ...attributes }}>
    {{- container_content -}}
</twig:Checkbox:Container>
