{# @prop variant 'primary'|'secondary'|'success'|'danger'|'warning'|'info'|'light'|'dark' The alert style variant. Defaults to `primary` #}
{# @prop dismissible boolean Whether the alert can be dismissed. Defaults to false #}
{# @prop heading string Optional heading for the alert #}
{# @block content The alert message content #}
{%- props 
    variant = 'primary',
    dismissible = false,
    heading = null
-%}

<div
    class="alert alert-{{ variant }}{% if dismissible %} alert-dismissible fade show{% endif %} {{ attributes.render('class') }}"
    role="alert"
    {{ attributes }}
>
    {% if heading %}
    <h4 class="alert-heading">{{ heading }}</h4>
    {% endif %}
    {%- block content %}{% endblock -%}
    {% if dismissible %}
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    {% endif %}
</div>
