{# @prop variant 'primary'|'secondary'|'success'|'danger'|'warning'|'info'|'light'|'dark' The visual style variant. Defaults to `primary` #}
{# @prop dismissible boolean Whether the alert can be dismissed. Defaults to false #}
{# @block content The alert content, typically includes `Alert:Title` and `Alert:Description` #}
{%- props variant = 'primary', dismissible = false -%}

<div
    class="alert alert-{{ variant }}{% if dismissible %} alert-dismissible fade show{% endif %} {{ attributes.render('class') }}"
    role="alert"
    {{ attributes }}
>
    {%- block content %}{% endblock -%}
    {% if dismissible %}<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>{% endif %}
</div>
