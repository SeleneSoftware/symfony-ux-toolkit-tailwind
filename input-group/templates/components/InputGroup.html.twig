{# @prop size 'sm'|'lg' The input group size. Defaults to normal #}
{# @block content The input field(s) (typically Input component) and other elements (typically InputGroup:Text components #}
{%- props 
    size = null
-%}

<div class="input-group{% if size %} input-group-{{ size }}{% endif %} {{ attributes.render('class') }}" {{ attributes }}>
    {%- block content %}{% endblock -%}
</div>
